<Window x:Class="Convertie.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Convertie"
        WindowStyle="ThreeDBorderWindow"
        ShowInTaskbar="True"
        ResizeMode="CanResize"
        Topmost="True"
        WindowStartupLocation="CenterScreen"
        ThemeMode="System"
        Title="Convertie"
        MinWidth="600" SizeToContent="WidthAndHeight">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="55"/>
        </Grid.RowDefinitions>

        <Grid x:Name="ContentGrid" Margin="10,0,10,10" >
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0"  x:Name="InputElementsGrid">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" x:Name="InputElementTitle" Text="From:" FontWeight="SemiBold" VerticalAlignment="Center" HorizontalAlignment="Left" Visibility="Collapsed"/>
                <ComboBox Grid.Row="1" Name="InputComboBox" VerticalAlignment="Center" HorizontalAlignment="Left" Margin="0,5,0,0" FontWeight="SemiBold" SelectionChanged="ComboBoxSelectionChanged" Visibility="Collapsed"/>
                <TextBlock Grid.Row="2" x:Name="InputHint" Text="Paste to convert!" Foreground="Gray" FontWeight="SemiBold" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                <TextBox Grid.Row="2" x:Name="InputTextBox" Background="Transparent" BorderThickness="1" Padding="10" FontSize="14" Margin="0,5,0,0"
                         HorizontalAlignment="Stretch" VerticalAlignment="Stretch" TextWrapping="Wrap" AcceptsReturn="True" AcceptsTab="True"
                         TextChanged="InputTextBox_TextChanged" LostFocus="InputTextBox_LostFocus" GotFocus="InputTextBox_GotFocus"/>
            </Grid>

            <Grid x:Name="OutputElementsGrid" Grid.Row="1" Margin="0,10,0,0" Visibility="Collapsed">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="To:" FontWeight="SemiBold" VerticalAlignment="Center" HorizontalAlignment="Left"/>
                <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,5,0,0">
                    <ComboBox Name="OutputComboBox" VerticalAlignment="Center" FontWeight="SemiBold" SelectionChanged="ComboBoxSelectionChanged"/>
                    <ComboBox Name="TextEncodingDecodingCombobox" VerticalAlignment="Center" FontWeight="SemiBold" Margin="10,0,0,0" SelectionChanged="ComboBoxSelectionChanged" Visibility="Collapsed"/>
                </StackPanel>
                <TextBox Grid.Row="2" x:Name="OutputTextBox" Background="Transparent" BorderThickness="1" Padding="10" FontSize="14" Margin="0,5,0,0"
                         HorizontalAlignment="Stretch" VerticalAlignment="Stretch" TextWrapping="Wrap" AcceptsReturn="True" AcceptsTab="True"/>
            </Grid>
        </Grid>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="55"/>
                <ColumnDefinition/>
            </Grid.ColumnDefinitions>
            
            <Button Grid.Column="0" Margin="10" Padding="5" Click="PanelViewChangeButtonClick">
                <Image x:Name="PanelChangeIcon"/>
            </Button>

            <Grid Grid.Column="1" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Margin="0,10,10,10">
                <Button HorizontalAlignment="Stretch" VerticalAlignment="Stretch" IsEnabled="False"/>
                <TextBlock x:Name="MessageTextBox" FontWeight="SemiBold" Text="Convert as you wish ;)" TextAlignment="Center" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                <TextBlock x:Name="ErrorTextBox" FontWeight="SemiBold" Foreground="Red" TextAlignment="Center" VerticalAlignment="Center" HorizontalAlignment="Center"/>
            </Grid>
        </Grid>
    </Grid>
</Window>
